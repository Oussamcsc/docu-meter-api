# Server-only internal API config. Never prefix these with NEXT_PUBLIC_.
DOCU_METER_API_URL=http://127.0.0.1:8000
ADMIN_API_TOKEN=<server-only-admin-token>

# Clerk auth. The publishable key is browser-safe; the secret key is server-only.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=<clerk-publishable-key>
CLERK_SECRET_KEY=<clerk-secret-key>
