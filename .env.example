# Copy this file to .env for Docker Compose, or to apps/api/.env for API-only local development.

# Postgres is the default Docker database.
POSTGRES_DB=docu_meter
POSTGRES_USER=docu_meter
POSTGRES_PASSWORD=docu_meter_password
DATABASE_URL=postgresql+psycopg://docu_meter:docu_meter_password@db:5432/docu_meter

# Local non-Docker fallback if you want SQLite instead:
# DATABASE_URL=sqlite:///./docu_meter.db

REDIS_URL=redis://redis:6379/0

API_KEY_PREFIX=dm_live
# Generate API_KEY_PEPPER with: python -c "import secrets; print(secrets.token_hex(32))"
API_KEY_PEPPER=replace-with-a-64-character-random-hex-string
ADMIN_API_TOKEN=replace-with-a-random-admin-token

RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60
MAX_DOCUMENT_CHARACTERS=50000

OPENAI_API_KEY=replace-with-openai-api-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=60

API_PORT=8000
WEB_PORT=3001

# Server-side URL used by the web container. Use http://127.0.0.1:8000 when running web outside Docker.
DOCU_METER_API_URL=http://api:8000

# Clerk auth. The publishable key is browser-safe; the secret key is server-only.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=replace-with-clerk-publishable-key
CLERK_SECRET_KEY=replace-with-clerk-secret-key
